# rival CLI — optional overrides
# Copy to ~/.rival/.env to customise. All values have built-in defaults.

# Descope project ID (required for login)
# DESCOPE_PROJECT_ID=

# Override the Rival API base URL
# RIVAL_API_URL=https://cortexone.rival.io

# Override token / org without running `rival login`
# RIVAL_TOKEN=
# RIVAL_ORG_ID=
