{
  "name": "@rival/cli",
  "version": "1.0.0",
  "description": "Rival CLI — manage and push function code to the Rival platform",
  "keywords": [
    "rival",
    "cli",
    "functions",
    "cortexone"
  ],
  "homepage": "https://rival.io",
  "author": "Rival <team@rival.io>",
  "license": "MIT",
  "bin": {
    "rival": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:macos-arm64": "node scripts/build.mjs macos-arm64",
    "build:macos-x64": "node scripts/build.mjs macos-x64",
    "build:linux-x64": "node scripts/build.mjs linux-x64",
    "build:win-x64": "node scripts/build.mjs win-x64",
    "build:all": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "inquirer": "^9.3.8",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.14.10",
    "@yao-pkg/pkg": "^5.11.5",
    "esbuild": "^0.27.4",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
